# ====== LLM & Embedding ======
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ====== Data Sources ======
POLYGON_API_KEY=your_polygon_api_key_here
ALPHA_VANTAGE_KEY=your_alpha_vantage_key_here
TUSHARE_TOKEN=optional_tushare_token
COINGECKO_API_KEY=optional_coingecko_key

# ====== Storage ======
DATABASE_URL=sqlite+aiosqlite:///./data/investment.db
CHROMA_PERSIST_DIR=./data/chroma

# ====== Web / API ======
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=production
SECRET_KEY=please_change_me_to_a_random_string
CORS_ORIGINS=*

# ====== Telegram Notifier ======
TELEGRAM_TOKEN=1234567890:ABCDEF_your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ====== Email Notifier (optional) ======
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=recipient@example.com

# ====== Scheduler ======
DAILY_REPORT_CRON=0 9 * * 1-5
WATCHLIST=AAPL,MSFT,TSLA,00700.HK,BTC-USD

# ====== Misc ======
LOG_LEVEL=INFO
RATE_LIMIT_PER_MINUTE=30
LANGUAGE=zh-CN
